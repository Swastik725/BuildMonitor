generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String?   @map("password_hash") // now optional — OAuth users won't have one
  fullName      String    @map("full_name")
  avatarUrl     String?   @map("avatar_url")
  emailVerified Boolean   @default(false) @map("email_verified")
  lastLogin     DateTime? @map("last_login")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // OAuth support
  authProviders AuthProvider[]

  deployments   Deployment[]   @relation("TriggeredBy")
  notifications Notification[]

  memberships OrganizationMember[]

  refreshTokens RefreshToken[]
}

model AuthProvider {
  id         String   @id @default(uuid())
  provider   String // "google" | "github" | "local"
  providerId String   @map("provider_id") // OAuth provider's user id (null/unused for local)
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([provider, providerId])
  @@map("auth_providers")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @map("token_hash") // store hash, never raw token
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  OrganizationMember[]
  projects Project[]

  alerts    Alert[]
  auditLogs AuditLog[]
}

model OrganizationMember {
  id             String           @id @default(uuid())
  userId         String
  organizationId String
  role           OrganizationRole @default(MEMBER)

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model Project {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  name           String
  slug           String
  description    String?
  visibility     Visibility
  defaultBranch  String        @map("default_branch")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  alerts         Alert[]
  environments   Environment[]
  organization   Organization  @relation(fields: [organizationId], references: [id])
  repository     Repository?
  incidents      Incident[]
  repositoryUrl  String?
  productionUrl  String?
  healthUrl      String?
  branch         String?       @default("main")
  healthEnabled  Boolean       @default(true)
  checkInterval  Int           @default(60)
  timeout        Int           @default(5000)
  expectedStatus Int           @default(200)
  expectedBody   String?

  @@index([organizationId])
  @@index([slug])
}

model Repository {
  id                 String     @id @default(uuid())
  projectId          String     @unique @map("project_id")
  githubRepositoryId String     @map("github_repository_id")
  githubOwner        String     @map("github_owner")
  repositoryName     String     @map("repository_name")
  cloneUrl           String     @map("clone_url")
  htmlUrl            String?    @map("html_url")
  defaultBranch      String     @map("default_branch")
  visibility         Visibility
  webhookSecret      String     @map("webhook_secret")
  isConnected        Boolean    @default(true) @map("is_connected")
  lastSync           DateTime?  @map("last_sync")
  latestCommitSha    String?    @map("latest_commit_sha")
  latestCommitMessage String?   @map("latest_commit_message")
  latestCommitAuthor String?    @map("latest_commit_author")
  latestCommitDate   DateTime?  @map("latest_commit_date")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")
  project            Project    @relation(fields: [projectId], references: [id])
}

model Environment {
  id              String          @id @default(uuid())
  projectId       String          @map("project_id")
  name            String
  environmentType EnvironmentType @map("environment_type")
  domain          String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deployments     Deployment[]
  project         Project         @relation(fields: [projectId], references: [id])
  healthChecks    HealthCheck[]
}

model Deployment {
  id            String           @id @default(uuid())
  environmentId String           @map("environment_id")
  triggeredById String           @map("triggered_by")
  commitSha     String           @map("commit_sha")
  commitMessage String           @map("commit_message")
  branch        String
  status        DeploymentStatus
  duration      Int?
  startedAt     DateTime?        @map("started_at")
  finishedAt    DateTime?        @map("finished_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  environment   Environment      @relation(fields: [environmentId], references: [id])
  triggeredBy   User             @relation("TriggeredBy", fields: [triggeredById], references: [id])
  logs          DeploymentLog[]
  metrics       Metric[]

  @@index([environmentId])
  @@index([status])
  @@index([branch])
  @@index([commitSha])
}

model DeploymentLog {
  id           String     @id @default(uuid())
  deploymentId String     @map("deployment_id")
  timestamp    DateTime
  logLevel     LogLevel   @map("log_level")
  message      String
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
}

model Metric {
  id           String     @id @default(uuid())
  deploymentId String     @map("deployment_id")
  metricType   MetricType @map("metric_type")
  value        Float
  recordedAt   DateTime   @map("recorded_at")
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
}

model HealthCheck {
  id String @id @default(uuid())

  environmentId String      @map("environment_id")
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  status String

  statusCode Int?

  responseTime Int?

  message String?

  checkedAt DateTime @default(now()) @map("checked_at")

  @@index([environmentId])
}

enum HealthStatus {
  HEALTHY
  UNHEALTHY
}

model Alert {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  projectId      String        @map("project_id")
  severity       AlertSeverity
  title          String
  description    String
  resolved       Boolean       @default(false)
  createdAt      DateTime      @default(now()) @map("created_at")
  organization   Organization  @relation(fields: [organizationId], references: [id])
  project        Project       @relation(fields: [projectId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  performedBy    String       @map("performed_by")
  action         String
  resource       String
  resourceId     String       @map("resource_id")
  ipAddress      String       @map("ip_address")
  userAgent      String       @map("user_agent")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Incident {
  id         String         @id @default(uuid())
  projectId  String         @map("project_id")
  title      String
  status     IncidentStatus @default(OPEN)
  openedAt   DateTime       @default(now()) @map("opened_at")
  resolvedAt DateTime?      @map("resolved_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  project    Project        @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([status])
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
}

enum MemberRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

enum MemberStatus {
  INVITED
  ACTIVE
  REMOVED
}

enum Visibility {
  PRIVATE
  PUBLIC
}

enum EnvironmentType {
  DEVELOPMENT
  STAGING
  PREVIEW
  PRODUCTION
}

enum DeploymentStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum LogLevel {
  INFO
  WARNING
  ERROR
  DEBUG
}

enum MetricType {
  CPU
  MEMORY
  LATENCY
  NETWORK
  DISK
  REQUESTS
  ERROR_RATE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}
